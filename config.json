  "crawl_config": {
    "keywords": {
      "primary": ["讲座", "报告", "研讨会", "学术报告", "特邀报告", "论坛", "沙龙", "讲堂", "大讲堂"],
      "activity": ["活动", "比赛", "竞赛", "双选会", "招聘会"],
      "series": [
        "杏林论坛",
        "双脑中心大讲堂",
        "钟子逸人文讲座",
        "径山讲堂",
        "观通学社学术沙龙",
        "浙大经院大讲堂",
        "CRPE双周青年学者论坛",
        "紫金港资本系列讲座"
      ],
      "exclude": ["会议通知", "放假通知", "考试安排", "选课"]
    },
    "schedule": {
      "library": {"frequency": "daily", "times": ["08:00", "20:00"]},
      "core_platforms": {"frequency": "daily", "times": ["08:00"]},
      "colleges": {"frequency": "every_6_hours", "times": ["08:00", "14:00", "20:00", "02:00"]},
      "wechat": {"frequency": "every_3_hours"}
    },
    "parser": {
      "zju_list": {
        "list_selector": ".list_box li, .news_list li",
        "title_selector": "a",
        "date_selector": ".date, span",
        "link_attr": "href"
      }
    }
  },
  "ai_extraction": {
    "model": "glm-4",
    "fields": [
