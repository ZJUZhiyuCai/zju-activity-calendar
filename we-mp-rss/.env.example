# 基础运行
APP_NAME=zju-activity-calendar-data
SERVER_NAME=zju-activity-calendar
WEB_NAME=浙大活动日历
PORT=8001
CONFIG_PATH=/app/config.yaml
START_MODE=api
TZ=Asia/Shanghai
AUTO_RELOAD=False
DEBUG=False

# 数据库
DB=sqlite:///data/db.db

# 维护权限
MAINTENANCE_ALLOW_LOCAL_UNAUTHENTICATED=False
SECRET_KEY=change-me-in-production
TOKEN_EXPIRE_MINUTES=4320
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
ADMIN_FORCE_UPDATE_PASSWORD=False
ADMIN_NICKNAME=Administrator

# 运行模式相关
STARTUP_ENABLE_AUTH_SERVICE=False
STARTUP_ENABLE_EMBEDDED_REDIS=False

# Redis
REDIS_ENABLED=False
REDIS_URL=redis://:123456@127.0.0.1:6379/0
REDIS_SERVER_ENABLED=False
REDIS_SERVER_HOST=0.0.0.0
REDIS_SERVER_PORT=6379
REDIS_SERVER_PASSWORD=123456

# 微信/公众号链路
WERSS_AUTH_WEB=True
WECHAT_ALLOWED_ACCOUNTS=

# 采集与代理
MAX_PAGE=5
PROXY_ENABLED=False
PROXY_HTTP_URL=
PROXY_DENO_URL=
BROWSER_TYPE=firefox

# 前端
VITE_API_BASE=/api/v1/wx
VITE_ENABLE_DEMO_FALLBACK=false
